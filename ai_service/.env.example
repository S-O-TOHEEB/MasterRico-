# ─────────────────────────────────────────────────────────────────────────────
# EduStream AI Service — Environment Variables
# Copy to .env and fill in real values.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Required — supports any OpenAI-compatible API
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini          # Cost-efficient default; swap to gpt-4o for better quality

# Optional: use a different base URL for Groq, Anthropic-compatible, etc.
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Internal Auth ─────────────────────────────────────────────────────────────
# Must match backend's AI_INTERNAL_API_KEY
INTERNAL_API_KEY=dev-internal-key-change-in-prod

# ── Service ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
