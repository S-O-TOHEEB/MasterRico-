{
  "name": "edustream-backend",
  "version": "2.0.0",
  "description": "EduStream — video-first structured learning platform",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "migration:generate": "typeorm-ts-node-esm migration:generate src/migrations/Migration -d src/config/database.ts",
    "migration:run": "typeorm-ts-node-esm migration:run -d src/config/database.ts",
    "migration:revert": "typeorm-ts-node-esm migration:revert -d src/config/database.ts",
    "migration:show": "typeorm-ts-node-esm migration:show -d src/config/database.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1090.0",
    "@aws-sdk/s3-request-presigner": "^3.1090.0",
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.13.2",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.6.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "livekit-server-sdk": "^2.17.0",
    "multer": "^2.2.0",
    "nodemailer": "^6.10.1",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "stripe": "^22.3.2",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.20",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.2.0",
    "@types/node": "^20.19.43",
    "@types/nodemailer": "^6.4.24",
    "@types/swagger-ui-express": "^4.1.6",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
