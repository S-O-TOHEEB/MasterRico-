# ─────────────────────────────────────────────────────────────────────────────
# EduStream Backend — Environment Variables
# Copy to .env and fill in real values before running locally or deploying.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# Comma-separated list of allowed CORS origins (use * for local dev only)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# This server's own publicly reachable URL — used to build accessUrl links
# for STORAGE_PROVIDER=local uploads (e.g. https://api.edustream.io). Safe
# to leave as localhost for local dev.
BACKEND_PUBLIC_URL=http://localhost:3000

# ── JWT ──────────────────────────────────────────────────────────────────────
# REQUIRED — the server refuses to boot without a real value here (see
# config/env.ts). Generate one with: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Local (docker-compose)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=edustream
DB_PASSWORD=edustream_dev
DB_NAME=edustream

# Production (Render PostgreSQL — paste the full connection string instead)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=        # set on production

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Paystack ─────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_PUBLIC_KEY=pk_test_...

# ── AI Microservice ───────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000
# Must match the AI service's INTERNAL_API_KEY
AI_INTERNAL_API_KEY=dev-internal-key-change-in-prod

# ── Storage (Cloud) — real, provider-selected via STORAGE_PROVIDER ───────────
# s3 | cloudinary | local (local is a genuine working dev fallback that writes
# to ./uploads on this server's disk — NOT recommended on Render without a
# persistent disk attached, since the filesystem is ephemeral on redeploy).
STORAGE_PROVIDER=local

# AWS S3 — required when STORAGE_PROVIDER=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-2
AWS_S3_BUCKET=edustream-media
# Optional: serve files through a CloudFront distribution instead of the raw
# S3 URL, e.g. https://cdn.edustream.io
AWS_CLOUDFRONT_URL=

# Cloudinary — required when STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Video (Mux) — real, independent of STORAGE_PROVIDER ──────────────────────
# All video uploads go through Mux regardless of which file-storage provider
# is selected above (see MuxService for why: Mux needs a resumable/TUS
# upload, which a plain presigned PUT can't do).
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
# Found in Mux dashboard → Settings → Webhooks, once you've added an
# endpoint pointing at https://your-api.com/api/v1/webhooks/mux
MUX_WEBHOOK_SECRET=

# ── Live sessions (LiveKit) — real ────────────────────────────────────────────
# LIVEKIT_URL is the wss:// address clients connect to (LiveKit Cloud gives
# you one per project; self-hosted uses your own domain). The server SDK
# also uses it for room management, over https on the same host.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://your-project.livekit.cloud

# ── Email (Brevo SMTP relay) ──────────────────────────────────────────────────
# Brevo dashboard → Settings → SMTP & API → SMTP tab for these values.
# BREVO_SMTP_USER is your Brevo login email; BREVO_SMTP_PASS is the generated
# SMTP key (NOT your Brevo account password).
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_SECURE=false
BREVO_SMTP_USER=
BREVO_SMTP_PASS=

# Must be a verified sender (or verified domain) in your Brevo account, or
# sends will fail even with valid SMTP credentials.
FROM_EMAIL=noreply@edustream.io
FROM_NAME=EduStream

# Used to build the link inside password-reset emails, e.g. {FRONTEND_URL}/reset-password?token=...
FRONTEND_URL=https://app.edustream.io

# Set to "true" to include OTPs / password-reset tokens directly in the API
# response (POST /auth/resend-otp, POST /auth/password-reset/request), in
# addition to actually emailing them. Handy while confirming Brevo is wired
# correctly. Leave unset (safe default) in real production.
EXPOSE_DEBUG_CODES=false

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Set to "true" to enable experimental features
ENABLE_LIVE_SESSIONS=false
ENABLE_AI_RECOMMENDATIONS=true
