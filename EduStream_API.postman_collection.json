{
  "info": {
    "name": "EduStream API v2",
    "description": "Complete collection for all 47 EduStream endpoints.\n\n**Setup:**\n1. Import this collection\n2. Create an Environment with variable `base_url = http://localhost:3000`\n3. Run `POST /auth/register` or `POST /auth/login` \u2014 the test script auto-saves the token\n4. All protected routes pick up `{{token}}` automatically",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "course_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "review_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "enrollment_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "path_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "cert_code",
      "value": "",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "section_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "lesson_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "post_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "reply_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "notification_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "System",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health",
            "description": "Returns service status. No auth required."
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json(); if (r.token) { pm.collectionVariables.set('token', r.token); pm.collectionVariables.set('user_id', r.user?.id || ''); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/v1/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"creator@test.com\",\n  \"password\": \"Password1!\",\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Doe\",\n  \"role\": \"creator\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json(); if (r.token) { pm.collectionVariables.set('token', r.token); pm.collectionVariables.set('user_id', r.user?.id || ''); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/v1/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"creator@test.com\",\n  \"password\": \"Password1!\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Courses",
      "item": [
        {
          "name": "List Published Courses",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/courses?page=1&limit=20",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "courses"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            }
          }
        },
        {
          "name": "Get Single Course",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/courses/{{course_id}}"
          }
        },
        {
          "name": "My Courses (Creator)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{base_url}}/api/v1/courses/my/courses"
          }
        },
        {
          "name": "Create Course",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json(); if (r.data?.id) pm.collectionVariables.set('course_id', r.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/v1/courses",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Introduction to TypeScript\",\n  \"description\": \"Learn TypeScript from scratch with real projects.\",\n  \"tagline\": \"Go from JS to TS in 10 hours\",\n  \"pricePence\": 2999,\n  \"currency\": \"GBP\",\n  \"difficultyLevel\": \"beginner\",\n  \"learningOutcomes\": [\"Understand type annotations\", \"Build typed APIs\"],\n  \"prerequisites\": [\"Basic JavaScript\"],\n  \"language\": \"en\"\n}"
            }
          }
        },
        {
          "name": "Update Course",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/v1/courses/{{course_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tagline\": \"Updated: Go from JS to TS in 8 hours\",\n  \"estimatedDurationMinutes\": 480\n}"
            }
          }
        },
        {
          "name": "Publish Course",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{base_url}}/api/v1/courses/{{course_id}}/publish"
          }
        },
        {
          "name": "Archive Course",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{base_url}}/api/v1/courses/{{course_id}}/archive"
          }
        },
        {
          "name": "Delete Course (draft only)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{base_url}}/api/v1/courses/{{course_id}}"
          }
        }
      ]
    },
    {
      "name": "Search",
      "item": [
        {
          "name": "Search Courses",
          "request": {
            "method": "GET",
